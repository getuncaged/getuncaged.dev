---
/**
 * /design — the living gallery for "Midnight", the Uncaged web design system.
 * Renders the real tokens and primitives from global.css, so this page and
 * the site cannot drift apart. Spec: DESIGN-SYSTEM.md. Unlisted + noindex.
 */
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';

const swatches = [
  { name: '--void', hex: '#0B0D12', note: 'page ground' },
  { name: '--ground-top', hex: '#12151D', note: 'top gradient' },
  { name: '--panel', hex: '#12151C', note: 'cards, rows' },
  { name: '--raised', hex: '#171B24', note: 'hover surfaces' },
  { name: 'band, deep', hex: '#0E1117', note: 'section bands' },
  { name: 'artifact', hex: '#10141C', note: 'window bodies' },
  { name: '--ink', hex: '#E8EBF2', note: 'primary text' },
  { name: '--ash', hex: '#8B93A5', note: 'body text' },
  { name: '--muted', hex: '#5D6577', note: 'micro labels' },
  { name: '--bar', hex: '#262C3A', note: 'borders' },
  { name: '--gold', hex: '#FFB23A', note: 'ok-states', warm: true },
  { name: '--ember', hex: '#FF7A18', note: 'THE accent', warm: true },
  { name: '--ember-deep', hex: '#FF5E10', note: 'pressed', warm: true },
  { name: '--flame', hex: '#FF4D1C', note: 'headline tail', warm: true },
];

const rules = [
  'One dark palette, everywhere — the base varies only through cool tonal bands.',
  'All bases are cool. A warm surface is a bug.',
  'Gold → ember → flame is the only accent family. No second hue.',
  'No pure white — text tops out at porcelain #E8EBF2.',
  'Product mockups mirror the real app: its layouts, labels and button vocabulary.',
  'Type floor 10.5px; anything meant to be read is 13.5px+ in --ash or brighter.',
];
---

<Base title="Midnight — Uncaged web design system" description="The living gallery of Midnight, the design system behind getuncaged.dev: tokens, type, and primitives rendered from the production CSS." noindex>
  <main class="ds">
    <div class="container">
      <header class="ds-head">
        <a href="/" class="ds-home" aria-label="Back to getuncaged.dev">
          <Logo idp="ds" size={30} />
        </a>
        <div>
          <p class="eyebrow">uncaged web · v1.0</p>
          <h1 class="section-h ds-title">Midnight</h1>
          <p class="section-sub">
            The design system of getuncaged.dev, rendered from the production CSS. Cold canvas, one
            warm accent: everything at rest is cool — anything that burns, matters. The written
            spec lives in <code>DESIGN-SYSTEM.md</code>; the logo keeps its own system, "Ember".
          </p>
        </div>
      </header>

      <hr class="hairline" />

      <!-- Rules -->
      <section class="ds-sec">
        <h2 class="ds-h">The hard rules</h2>
        <ol class="ds-rules">
          {rules.map((r) => <li>{r}</li>)}
        </ol>
      </section>

      <!-- Palette -->
      <section class="ds-sec">
        <h2 class="ds-h">Color</h2>
        <p class="ds-note">≥90% cool, ≤10% warm. On ember fills the label is #16100A, never white.</p>
        <div class="ds-swatches">
          {
            swatches.map((s) => (
              <div class="ds-swatch">
                <div class={`ds-chip${s.warm ? ' ds-chip-warm' : ''}`} style={`background:${s.hex}`}></div>
                <code>{s.name}</code>
                <span>{s.hex} · {s.note}</span>
              </div>
            ))
          }
        </div>
        <p class="ds-note">
          Terminal-diegetic (inside mockup glass only): fail <b style="color:#ff3b47">#FF3B47</b>,
          diff-add <b style="color:#7bd88f">#7BD88F</b>, diff-del <b style="color:#ff8089">#FF8089</b>.
        </p>
      </section>

      <!-- Type -->
      <section class="ds-sec">
        <h2 class="ds-h">Typography</h2>
        <p class="ds-note">JetBrains Mono for every short string; Inter for sentences.</p>
        <div class="ds-type">
          <p class="ds-spec-display">No cage.<span class="ds-flame">▮</span></p>
          <span class="ds-tag">display · mono 800 · clamp(46–68px)</span>
          <p class="ds-spec-h2">Every model. No middleman.</p>
          <span class="ds-tag">section H2 · mono 700 · clamp(30–42px)</span>
          <p class="ds-spec-body">
            The AI inside Uncaged runs on a model you choose: a local runtime, your own API key, or
            a CLI agent. Body text is Inter 17px on a 1.65 line at 52–56ch.
          </p>
          <span class="ds-tag">body · inter 400 · 17px · --ash</span>
          <p class="eyebrow" style="margin:0">01 · no cloud</p>
          <span class="ds-tag">eyebrow · mono 500 · 13px · numbered stage rail</span>
        </div>
      </section>

      <!-- Buttons -->
      <section class="ds-sec">
        <h2 class="ds-h">Buttons</h2>
        <div class="ds-row">
          <a class="btn btn-primary" href="#top">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 2.75v7"></path><path d="M4.75 6.75 8 10l3.25-3.25"></path><path d="M3 13.25h10"></path>
            </svg>
            Primary
          </a>
          <a class="btn btn-ghost" href="#top">Ghost</a>
          <a class="btn btn-ghost btn-small" href="#top">Ghost small</a>
        </div>
        <p class="ds-note">
          Primary: gradient face, warm-black label, ember glow; hover lifts 1px and deepens. Icons
          are 1.8px strokes, round caps.
        </p>
      </section>

      <!-- Code block -->
      <section class="ds-sec">
        <h2 class="ds-h">Code block</h2>
        <div class="codeblock ds-cmd">
          <pre><span class="prompt">❯</span> curl -LO https://github.com/getuncaged/uncaged/releases/latest/download/Uncaged-macos-aarch64.dmg</pre>
          <button class="copy-btn" data-copy="curl -LO https://github.com/getuncaged/uncaged/releases/latest/download/Uncaged-macos-aarch64.dmg" aria-label="Copy sample command">copy</button>
        </div>
        <p class="ds-note">Ember prompt, right-cap copy control, 26px fade — commands never die under a button.</p>
      </section>

      <!-- Window chrome -->
      <section class="ds-sec">
        <h2 class="ds-h">Window chrome</h2>
        <div class="ds-window">
          <div class="ds-winbar">
            <span class="ds-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="ds-wintitle">settings — AI · connect a model</span>
            <span class="ds-winhint">one connection is all it takes</span>
          </div>
          <div class="ds-winbody">
            <div class="ds-mockrow">
              <div>
                <span class="ds-mockname">Ollama</span>
                <span class="ds-mockblurb">open models on your own machine</span>
              </div>
              <span class="ds-btns"><span class="ds-inuse">In use</span><span class="ds-editbtn">Edit</span></span>
            </div>
            <div class="ds-mockrow">
              <div>
                <span class="ds-mockname">Anthropic</span>
                <span class="ds-mockblurb">Claude Opus, Sonnet &amp; Haiku</span>
              </div>
              <span class="ds-btns"><span class="ds-editbtn">Connect</span></span>
            </div>
          </div>
        </div>
        <p class="ds-note">
          14px radius, #10141C body, dotted header on rgba(22,26,35,.6). Mockup buttons use the real
          app's vocabulary: Connect · Use · Edit · In use.
        </p>
      </section>

      <!-- Chips -->
      <section class="ds-sec">
        <h2 class="ds-h">Chips &amp; badges</h2>
        <div class="ds-row">
          <span class="ds-badge">Your login</span>
          <span class="ds-badge">On-device</span>
          <span class="ds-badge">API key</span>
          <span class="ds-badge ds-badge-gold">v0.1.0</span>
          <span class="ds-badge ds-badge-gold">In use</span>
        </div>
      </section>

      <!-- Motion -->
      <section class="ds-sec">
        <h2 class="ds-h">Motion</h2>
        <p class="ds-note">
          Hovers at 140ms. Sanctioned loops only — each says something: the cursor blinks
          <span class="cursor-blink" style="vertical-align:middle"></span> because the terminal is
          alive; orbs drift; sparks rise; the wire pulses once per call. Scroll-reveals are banned.
          Everything dies under <code>prefers-reduced-motion</code>.
        </p>
      </section>

      <footer class="ds-foot">
        <a href="/" class="ds-back">← getuncaged.dev</a>
        <span>Midnight v1.0 · spec in DESIGN-SYSTEM.md</span>
      </footer>
    </div>
  </main>
</Base>

<style>
  .ds {
    padding: 96px 0 72px;
  }

  .ds-head {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    margin-bottom: 56px;
  }

  .ds-home {
    color: var(--ink);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .ds-title {
    margin-bottom: 4px;
  }

  .ds-head .section-sub code {
    font-size: 14px;
    color: var(--ink);
  }

  .ds-sec {
    padding: 56px 0 0;
  }

  .ds-h {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 18px;
  }

  .ds-note {
    color: var(--ash);
    font-size: 14.5px;
    max-width: 72ch;
    margin-top: 14px;
  }

  .ds-note code {
    font-size: 13px;
    color: var(--ink);
  }

  .ds-rules {
    margin: 0;
    padding-left: 22px;
    color: var(--ash);
    font-size: 15.5px;
    line-height: 2;
    max-width: 78ch;
  }

  .ds-rules li::marker {
    font-family: var(--mono);
    color: var(--ember);
    font-weight: 700;
  }

  .ds-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 16px;
  }

  .ds-swatch {
    display: grid;
    gap: 5px;
  }

  .ds-chip {
    height: 56px;
    border-radius: 10px;
    border: 1px solid var(--bar);
  }

  .ds-chip-warm {
    border-color: rgba(255, 122, 24, 0.4);
  }

  .ds-swatch code {
    font-size: 12px;
    color: var(--ink);
  }

  .ds-swatch span {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--muted);
  }

  .ds-type {
    display: grid;
    gap: 6px;
  }

  .ds-spec-display {
    font-family: var(--mono);
    font-weight: 800;
    font-size: clamp(46px, 5vw, 68px);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .ds-flame {
    background: var(--grad-prompt);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .ds-spec-h2 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(30px, 3.6vw, 42px);
    color: var(--ink);
    margin-top: 22px;
  }

  .ds-spec-body {
    color: var(--ash);
    font-size: 17px;
    max-width: 56ch;
    margin-top: 22px;
  }

  .ds-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .ds-tag:last-of-type {
    margin-bottom: 0;
  }

  .eyebrow {
    margin-top: 22px;
  }

  .ds-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
  }

  .ds-cmd {
    display: flex;
    align-items: stretch;
    max-width: 720px;
  }

  .ds-cmd pre {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    padding: 13px 14px;
    -webkit-mask-image: linear-gradient(90deg, #000 calc(100% - 26px), transparent);
    mask-image: linear-gradient(90deg, #000 calc(100% - 26px), transparent);
  }

  .ds-cmd .copy-btn {
    position: static;
    flex-shrink: 0;
    border: 0;
    border-left: 1px solid var(--bar);
    border-radius: 0 11px 11px 0;
    padding: 0 13px;
    background: rgba(22, 26, 35, 0.6);
  }

  .ds-window {
    max-width: 560px;
    background: #10141c;
    border: 1px solid var(--bar);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(232, 235, 242, 0.05) inset,
      0 24px 70px -18px rgba(0, 0, 0, 0.85);
  }

  .ds-winbar {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--bar);
    background: rgba(22, 26, 35, 0.6);
  }

  .ds-dots {
    display: inline-flex;
    gap: 6px;
  }

  .ds-dots i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bar);
  }

  .ds-dots i:first-child {
    background: #384051;
  }

  .ds-wintitle {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ash);
    flex: 1;
  }

  .ds-winhint {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
  }

  .ds-winbody {
    padding: 16px;
    display: grid;
    gap: 8px;
  }

  .ds-mockrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--line-soft);
    border-radius: 10px;
    padding: 10px 12px;
  }

  .ds-mockrow:first-child {
    border-color: rgba(255, 178, 58, 0.35);
    background: rgba(255, 178, 58, 0.06);
  }

  .ds-mockrow > div {
    display: grid;
    gap: 2px;
  }

  .ds-mockname {
    font-family: var(--mono);
    font-size: 12.5px;
    font-weight: 700;
    color: var(--ink);
  }

  .ds-mockblurb {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }

  .ds-btns {
    display: inline-flex;
    gap: 6px;
  }

  .ds-editbtn,
  .ds-inuse {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 700;
    border-radius: 7px;
    padding: 4px 10px;
    border: 1px solid var(--bar);
    color: var(--ash);
  }

  .ds-inuse {
    color: #16100a;
    background: var(--gold);
    border-color: var(--gold);
  }

  .ds-badge {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ash);
    border: 1px solid var(--bar);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .ds-badge-gold {
    color: #16100a;
    background: var(--gold);
    border-color: var(--gold);
    font-weight: 700;
  }

  .ds-foot {
    margin-top: 72px;
    padding-top: 24px;
    border-top: 1px solid var(--bar);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--muted);
  }

  .ds-back {
    color: var(--ash);
  }

  .ds-back:hover {
    color: var(--ink);
  }
</style>
