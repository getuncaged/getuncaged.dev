---
import Logo from './Logo.astro';
import { SITE } from '../data/site';

const links = [
  { href: '#privacy', label: 'no cloud' },
  { href: '#models', label: 'any model' },
  { href: '#open-source', label: 'built to fork' },
  { href: '#download', label: 'install' },
  { href: '#faq', label: 'questions' },
];
---

<header class="nav" id="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="Uncaged home">
      <Logo idp="nav" size={27} class="brand-mark" />
      <span class="brand-word">uncaged</span>
      <span class="brand-cursor" aria-hidden="true"></span>
    </a>

    <nav class="nav-links" aria-label="Site">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-actions">
      <a class="gh-link" href={SITE.github} target="_blank" rel="noopener" aria-label="Uncaged on GitHub">
        <svg width="19" height="19" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>
      <button class="btn btn-primary btn-small nav-dl" type="button" data-install-copy aria-label="Copy the install command">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="6" y="6" width="8" height="8" rx="1.5"></rect>
          <path d="M4 10H3.2A1.2 1.2 0 0 1 2 8.8V3.2A1.2 1.2 0 0 1 3.2 2h5.6A1.2 1.2 0 0 1 10 3.2V4"></path>
        </svg>
        <span data-copy-label>copy install</span>
      </button>
      <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a href={SITE.github} target="_blank" rel="noopener">github ↗</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background-color var(--fast), border-color var(--fast);
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(11, 13, 18, 0.85);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--bar);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    height: 68px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    color: var(--ink);
  }

  .brand-word {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: 0.01em;
  }

  .brand-cursor {
    width: 8px;
    height: 19px;
    border-radius: 2px;
    background: var(--grad-prompt);
    margin-left: -4px;
  }

  .nav-links {
    display: flex;
    gap: 30px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links a {
    font-family: var(--mono);
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ash);
    transition: color var(--fast);
    /* bigger touch/click target without moving the optical layout */
    padding: 10px 4px;
    margin: -10px -4px;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .nav-links a.active {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 7px;
    text-decoration-color: var(--ember);
    text-decoration-thickness: 2px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .gh-link {
    color: var(--ash);
    display: inline-flex;
    transition: color var(--fast);
  }

  .gh-link:hover {
    color: var(--ink);
  }

  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 8px 2px;
    cursor: pointer;
  }

  .menu-btn span {
    width: 20px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform var(--fast), opacity var(--fast);
  }

  .menu-btn[aria-expanded='true'] span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .menu-btn[aria-expanded='true'] span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 10px 24px 22px;
    background: rgba(11, 13, 18, 0.96);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--bar);
  }

  .mobile-menu a {
    font-family: var(--mono);
    font-size: 15px;
    color: var(--ink);
    padding: 13px 2px;
    border-bottom: 1px solid rgba(60, 67, 82, 0.5);
  }

  .mobile-menu a:last-child {
    border-bottom: 0;
  }

  .mobile-menu.open {
    display: flex;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .menu-btn {
      display: flex;
    }
  }

  @media (max-width: 560px) {
    .nav-dl {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
  menu.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    })
  );

  // scrollspy: light the nav link for the stage on screen
  const spyIds = ['privacy', 'models', 'open-source', 'download', 'faq'];
  const navLinks = new Map(
    spyIds.map((id) => [id, document.querySelector(`.nav-links a[href="#${id}"]`)])
  );
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          navLinks.forEach((l) => {
            l?.classList.remove('active');
            l?.removeAttribute('aria-current');
          });
          const link = navLinks.get(e.target.id);
          link?.classList.add('active');
          link?.setAttribute('aria-current', 'true');
        }
      }
    },
    { rootMargin: '-35% 0px -60% 0px' }
  );
  spyIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) spy.observe(el);
  });

  // above the first stage, no lamp should be lit
  const hero = document.getElementById('top');
  if (hero) {
    const clearSpy = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          navLinks.forEach((l) => {
            l?.classList.remove('active');
            l?.removeAttribute('aria-current');
          });
        }
      },
      { rootMargin: '-35% 0px -60% 0px' }
    );
    clearSpy.observe(hero);
  }
</script>
