---
import Logo from './Logo.astro';
import { SITE } from '../data/site';
---

<section class="cta">
  <div class="sparks" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
  <div class="container cta-inner">
    <Logo idp="cta" size={76} class="cta-mark" />
    <h2 class="cta-h">Your terminal. Your models.<br />Uncaged.</h2>
    <p class="cta-sub">Thirty seconds from download to a working agent — none of them spent on a sign-up form.</p>
    <div class="cta-btns">
      <button class="install-cmd" type="button" data-install-copy aria-label="Copy the install command">
        <code><span class="hi-prompt">$</span><span data-install-cmd>curl -fsSL https://getuncaged.dev/install.sh | bash</span></code>
        <span class="hi-copy" data-copy-label>copy</span>
      </button>
      <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noopener">Star on GitHub</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding-block: 130px;
    text-align: center;
    overflow: clip;
  }

  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(46% 52% at 50% 96%, rgba(255, 122, 24, 0.09), transparent 66%);
    animation: breathe 16s ease-in-out -8s infinite alternate;
    z-index: 0;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-mark {
    color: var(--ink);
    margin-bottom: 34px;
  }

  .cta-h {
    font-size: clamp(30px, 4.4vw, 46px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .cta-sub {
    margin-top: 18px;
    color: var(--ash);
    max-width: 46ch;
  }

  .cta-btns {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 36px;
  }
</style>
