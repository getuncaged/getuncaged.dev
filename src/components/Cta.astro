---
import Logo from './Logo.astro';
import { SITE } from '../data/site';
---

<section class="cta">
  <div class="container cta-inner">
    <Logo idp="cta" size={76} class="cta-mark" />
    <h2 class="cta-h">Your terminal. Your models.<br />Uncaged.</h2>
    <p class="cta-sub">Thirty seconds from download to a working agent — none of them spent on a sign-up form.</p>
    <div class="cta-btns">
      <a class="btn btn-primary" href={SITE.dmg} data-dl-mac>
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 1v9.3L4.9 7.2 3.8 8.3 8 12.5l4.2-4.2-1.1-1.1L8 10.3V1H8zM2 13.5h12V15H2v-1.5z"></path>
        </svg>
        Download for macOS
      </a>
      <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noopener">Star on GitHub</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: 130px;
    text-align: center;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-mark {
    color: var(--ink);
    margin-bottom: 34px;
  }

  .cta-h {
    font-size: clamp(30px, 4.4vw, 46px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .cta-sub {
    margin-top: 18px;
    color: var(--ash);
    max-width: 46ch;
  }

  .cta-btns {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 36px;
  }
</style>
