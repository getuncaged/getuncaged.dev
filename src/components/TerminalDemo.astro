---
/**
 * The hero product visual: a hand-built Uncaged session that types itself out
 * once it scrolls into view — a failing test, the agent diagnosing it with a
 * local model, the fix, the green rerun. After the run, the model chip cycles
 * to make the point: same session, any brain.
 */
---

<div class="term-scene" aria-hidden="false">
  <svg class="cage-frame" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path
      clip-path="url(#cage-frame-gap)"
      d="M31 22 H86 C97 22 101 28 96 38 L86 60 L96 82 C101 92 97 98 86 98 H31 Q19 98 19 86 V34 Q19 22 31 22 Z"
      fill="none"
      stroke="#E9E1D4"
      stroke-width="2.6"
      stroke-linejoin="round"></path>
    <defs>
      <clipPath id="cage-frame-gap">
        <path clip-rule="evenodd" d="M0 0 H120 V120 H0 Z M78 49 H108 V71 H78 Z"></path>
      </clipPath>
    </defs>
  </svg>

  <figure class="term" id="term-demo" role="img" aria-label="Demo of an Uncaged agent session fixing a failing Rust test with a locally-run model">
    <figcaption class="term-bar">
      <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="term-title">~/dev/tide — uncaged</span>
      <span class="model-chip" id="model-chip">
        <svg width="10" height="10" viewBox="30 42 30 36" aria-hidden="true">
          <polyline points="36,49 52,60 36,71" fill="none" stroke="#FF7A18" stroke-width="9" stroke-linecap="round" stroke-linejoin="round"></polyline>
        </svg>
        <span id="model-chip-label">ollama · qwen3-coder</span>
      </span>
    </figcaption>

    <div class="term-body" id="term-body">
      <div class="t-block" data-step>
        <p class="t-cmd"><span class="t-caret">❯</span><span class="t-typed" data-text="cargo test"></span></p>
        <pre class="t-out t-reveal">     Running 24 tests
test auth::session_refresh ... <b class="t-bad">FAILED</b>

thread 'auth::session_refresh' panicked at src/auth.rs:142:
assertion failed: token.is_fresh()</pre>
        <p class="t-meta t-reveal">~/dev/tide · <span class="t-bad">exit 101</span></p>
      </div>

      <div class="t-block" data-step>
        <p class="t-cmd"><span class="t-caret">❯</span><span class="t-typed" data-text="why is session_refresh failing?"></span></p>
        <div class="t-agent t-reveal">
          <p class="t-agent-head">
            <svg width="11" height="13" viewBox="30 42 30 36" aria-hidden="true">
              <defs>
                <linearGradient id="td-cg" gradientUnits="userSpaceOnUse" x1="44" y1="49" x2="52" y2="71">
                  <stop offset="0" stop-color="#FFB23A"></stop>
                  <stop offset="1" stop-color="#FF7A18"></stop>
                </linearGradient>
              </defs>
              <polyline points="36,49 52,60 36,71" fill="none" stroke="url(#td-cg)" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></polyline>
            </svg>
            <span>agent</span>
            <span class="t-agent-model">qwen3-coder · local</span>
          </p>
          <p class="t-agent-p">
            <code>is_fresh()</code> reads the clock after re-acquiring the write lock — past the test's
            50&nbsp;ms expiry window. Pin the timestamp first:
          </p>
          <pre class="t-diff"><span class="t-del">- if token.expires_at &lt; Utc::now() {</span>
<span class="t-add">+ let now = Utc::now();</span>
<span class="t-add">+ if token.expires_at &lt; now {</span></pre>
          <p class="t-agent-p">Patched <code>src/auth.rs</code>. Re-running —</p>
        </div>
      </div>

      <div class="t-block" data-step>
        <p class="t-cmd"><span class="t-caret">❯</span><span class="t-typed" data-text="cargo test auth::session_refresh"></span></p>
        <pre class="t-out t-reveal">test auth::session_refresh ... <b class="t-ok">ok</b></pre>
        <p class="t-meta t-reveal">~/dev/tide · <span class="t-ok">exit 0 ✓</span></p>
      </div>

      <p class="t-idle t-show" id="t-idle"><span class="t-caret">❯</span><span class="cursor-blink"></span></p>
    </div>
  </figure>
</div>

<style>
  .term-scene {
    position: relative;
    --cage-size: 720px;
  }

  .cage-frame {
    position: absolute;
    width: var(--cage-size);
    height: var(--cage-size);
    top: -27%;
    right: 30px;
    opacity: 0.15;
    pointer-events: none;
  }

  .term {
    position: relative;
    margin: 0;
    background: #161412;
    border: 1px solid var(--bar);
    border-radius: 14px;
    box-shadow:
      0 1px 0 rgba(233, 225, 212, 0.05) inset,
      0 24px 70px -18px rgba(0, 0, 0, 0.85),
      0 8px 24px -12px rgba(0, 0, 0, 0.7);
    overflow: hidden;
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--bar);
    background: rgba(34, 30, 26, 0.6);
  }

  .dots {
    display: inline-flex;
    gap: 6px;
  }

  .dots i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bar);
  }

  .dots i:first-child {
    background: #46403a;
  }

  .term-title {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ash);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: center;
  }

  .model-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 500;
    color: var(--ash);
    border: 1px solid var(--bar);
    border-radius: 999px;
    padding: 4px 10px;
    transition: opacity 0.25s ease;
    white-space: nowrap;
  }

  .model-chip.swap {
    opacity: 0;
  }

  .term-body {
    padding: 18px 20px 14px;
    height: 500px;
    overflow-y: auto;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.62;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scrollbar-width: none;
  }

  .term-body::-webkit-scrollbar {
    display: none;
  }

  .t-block {
    display: none;
  }

  .t-block.t-show {
    display: block;
  }

  .t-cmd {
    color: var(--ink);
    font-weight: 500;
  }

  .t-caret {
    color: var(--ember);
    font-weight: 700;
    margin-right: 9px;
  }

  .t-block.typing .t-typed::after {
    content: '';
    display: inline-block;
    width: 7px;
    height: 14px;
    margin-left: 2px;
    vertical-align: -2px;
    border-radius: 1.5px;
    background: var(--grad-prompt);
  }

  .t-reveal {
    visibility: hidden;
  }

  .t-reveal.t-show {
    visibility: visible;
  }

  .t-out {
    margin: 8px 0 0;
    color: #b8ad9c;
    white-space: pre-wrap;
  }

  .t-out b {
    font-weight: 700;
  }

  .t-bad {
    color: #ff3b47;
  }

  .t-ok {
    color: var(--teal);
  }

  .t-meta {
    margin-top: 7px;
    font-size: 10.5px;
    color: var(--muted, #7a7368);
  }

  .t-agent {
    margin-top: 10px;
    border-left: 2px solid var(--bar);
    padding: 2px 0 2px 14px;
    display: grid;
    gap: 9px;
  }

  .t-agent-head {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
  }

  .t-agent-model {
    font-weight: 500;
    color: var(--muted, #7a7368);
  }

  .t-agent-p {
    color: #b8ad9c;
    font-size: 12.5px;
  }

  .t-agent-p code {
    color: var(--ink);
  }

  .t-diff {
    margin: 0;
    padding: 10px 12px;
    background: rgba(18, 17, 16, 0.7);
    border: 1px solid var(--bar);
    border-radius: 8px;
  }

  .t-del {
    color: var(--muted, #7a7368);
    text-decoration: line-through;
    text-decoration-color: rgba(148, 139, 126, 0.5);
  }

  .t-add {
    color: var(--gold);
  }

  .t-idle {
    display: none;
  }

  .t-idle.t-show {
    display: block;
  }

  @media (max-width: 1100px) {
    .cage-frame {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .term-body {
      height: 440px;
      font-size: 11.5px;
      padding: 14px 14px 12px;
    }

    .term-title {
      display: none;
    }
  }
</style>

<script>
  const demo = document.getElementById('term-demo');
  if (demo) {
    const body = document.getElementById('term-body')!;
    const idle = document.getElementById('t-idle')!;
    const steps = Array.from(demo.querySelectorAll<HTMLElement>('[data-step]'));
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
    const stick = () => {
      body.scrollTop = body.scrollHeight;
    };

    const chipLabel = document.getElementById('model-chip-label')!;
    const chip = document.getElementById('model-chip')!;
    const brains = ['ollama · qwen3-coder', 'anthropic · api key', 'claude code · your plan', 'lm studio · local'];

    function cycleChip() {
      if (reduced) return;
      let i = 0;
      setInterval(async () => {
        i = (i + 1) % brains.length;
        chip.classList.add('swap');
        await sleep(250);
        chipLabel.textContent = brains[i]!;
        chip.classList.remove('swap');
      }, 3200);
    }

    async function typeInto(el: HTMLElement) {
      const text = el.dataset.text ?? '';
      for (const ch of text) {
        el.textContent += ch;
        stick();
        await sleep(24 + Math.random() * 26);
      }
    }

    async function run() {
      await sleep(150);
      idle.classList.remove('t-show');
      for (const step of steps) {
        step.classList.add('t-show', 'typing');
        stick();
        const typed = step.querySelector<HTMLElement>('.t-typed');
        if (typed) {
          await sleep(350);
          await typeInto(typed);
        }
        step.classList.remove('typing');
        await sleep(300);
        for (const out of step.querySelectorAll('.t-reveal')) {
          out.classList.add('t-show');
          stick();
          await sleep(460);
        }
        await sleep(650);
      }
      idle.classList.add('t-show');
      stick();
      cycleChip();
    }

    function showFinal() {
      steps.forEach((s) => {
        s.classList.add('t-show');
        s.querySelectorAll('.t-reveal').forEach((o) => o.classList.add('t-show'));
        const typed = s.querySelector<HTMLElement>('.t-typed');
        if (typed) typed.textContent = typed.dataset.text ?? '';
      });
      idle.classList.add('t-show');
    }

    if (reduced) {
      showFinal();
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            io.disconnect();
            run();
          }
        },
        { threshold: 0.35 }
      );
      io.observe(demo);
    }
  }
</script>
