---
/**
 * One thin moving line instead of a whole section: everything Warp got
 * right came along. Duplicated list = seamless marquee loop.
 */
const kept = [
  'blocks',
  'agent mode',
  'code review',
  'tools panel',
  'workflows',
  'keymaps',
  'ide-grade editing',
  'gpu-fast rendering',
  'synced with upstream warp',
];
---

<div class="kept">
  <p class="sr-only">Everything Warp got right, kept: {kept.join(', ')}.</p>
  <p class="kept-label" aria-hidden="true">kept from warp</p>
  <div class="kept-track" aria-hidden="true">
    <div class="kept-run">
      {[...kept, ...kept].map((k) => <span><b>❯</b> {k}</span>)}
    </div>
  </div>
</div>

<style>
  .kept {
    display: flex;
    align-items: center;
    border-block: 1px solid var(--bar);
    background: rgba(18, 21, 29, 0.5);
    overflow: hidden;
  }

  .kept-label {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 11.5px;
    font-weight: 700;
    color: var(--ash);
    letter-spacing: 0.05em;
    padding: 14px 22px;
    border-right: 1px solid var(--bar);
    background: var(--void);
    position: relative;
    z-index: 1;
  }

  .kept-track {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }

  .kept-run {
    display: inline-flex;
    gap: 44px;
    padding-left: 44px;
    white-space: nowrap;
    width: max-content;
    animation: marquee 36s linear infinite;
  }

  .kept-run span {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ash);
  }

  .kept-run b {
    color: var(--ember);
    margin-right: 9px;
  }

  @media (prefers-reduced-motion: reduce) {
    .kept-run {
      animation: none;
    }
  }
</style>
