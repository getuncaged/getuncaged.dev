---
import TerminalDemo from './TerminalDemo.astro';
import { SITE } from '../data/site';
---

<section class="hero" id="top">
  <div class="sparks" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">a fork of the open-source warp terminal</p>
      <h1 class="hero-h">
        No account.<br />No cloud.<br /><span class="h-flame">No cage.</span><span class="cursor-blink" aria-hidden="true"></span>
      </h1>
      <p class="hero-sub">
        Uncaged is the open-source Warp terminal with the cloud cut out — the same agentic
        terminal, running entirely on your machine. Bring any model: a local runtime, an API key,
        or the CLI plan you already pay for. Your keys never leave your device.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" id="hero-dl" href={SITE.dmg} data-dl-mac>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1v9.3L4.9 7.2 3.8 8.3 8 12.5l4.2-4.2-1.1-1.1L8 10.3V1H8zM2 13.5h12V15H2v-1.5z"></path>
          </svg>
          <span id="hero-dl-label">Download for macOS</span>
        </a>
        <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noopener">View source</a>
      </div>
      <p class="hero-meta">
        free forever · AGPL-3.0 · macOS (Apple&nbsp;Silicon) · <a href="#download">Linux &amp; Windows in the works</a>
      </p>
    </div>

    <div class="hero-visual">
      <TerminalDemo />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 168px;
    padding-bottom: 96px;
    overflow: clip;
  }

  /* the one ember in the room, breathing slowly */
  .hero::before {
    content: '';
    position: absolute;
    inset: -12% -8% 0;
    pointer-events: none;
    background: radial-gradient(44% 38% at 64% 24%, rgba(255, 122, 24, 0.11), transparent 64%);
    animation: breathe 13s ease-in-out infinite alternate;
    z-index: 0;
  }

  /* fine workbench grid, fading in around the terminal */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(230, 235, 245, 0.07) 1px, transparent 1.3px);
    background-size: 27px 27px;
    -webkit-mask-image: radial-gradient(56% 64% at 66% 40%, #000 20%, transparent 74%);
    mask-image: radial-gradient(56% 64% at 66% 40%, #000 20%, transparent 74%);
    z-index: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 30fr) minmax(0, 34fr);
    gap: 64px;
    align-items: center;
  }

  .hero-h {
    font-size: clamp(42px, 4.9vw, 62px);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
  }

  .h-flame {
    background: linear-gradient(98deg, var(--gold) 8%, var(--ember) 55%, var(--flame) 96%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-sub {
    margin-top: 26px;
    color: var(--ash);
    font-size: 17.5px;
    max-width: 54ch;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .hero-meta {
    margin-top: 22px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted, #5d6577);
  }

  .hero-meta a {
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--bar);
  }

  .hero-meta a:hover {
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .hero {
      padding-top: 132px;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 56px;
    }

    .hero-sub {
      max-width: 62ch;
    }
  }
</style>

<script>
  // If the visitor clearly isn't on macOS, route the primary CTA to the
  // downloads section instead of the .dmg.
  const ua = navigator.userAgent;
  const isMac = /Mac|iPhone|iPad/.test(ua);
  if (!isMac) {
    const btn = document.getElementById('hero-dl') as HTMLAnchorElement | null;
    const label = document.getElementById('hero-dl-label');
    if (btn && label) {
      btn.href = '#download';
      label.textContent = 'Get Uncaged';
    }
  }
</script>
