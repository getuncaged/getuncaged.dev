---
import TerminalDemo from './TerminalDemo.astro';
import { SITE } from '../data/site';
---

<section class="hero" id="top">
  <div class="sparks" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">a fork of the open-source warp terminal</p>
      <h1 class="hero-h">
        Your terminal.<br />Your models.<br /><span class="h-flame">Uncaged.</span><span class="cursor-blink" aria-hidden="true"></span>
      </h1>
      <p class="hero-sub">
        Uncaged is the open-source Warp terminal with the cloud cut out — the same agentic
        terminal, running entirely on your machine. Bring any model: a local runtime, an API key,
        or the CLI plan you already pay for. Your keys never leave your device.
      </p>
      <div class="hero-ctas">
        <button class="install-cmd" type="button" data-install-copy aria-label="Copy the install command">
          <code><span class="hi-prompt">$</span><span data-install-cmd>curl -fsSL https://getuncaged.dev/install.sh | bash</span></code>
          <span class="hi-copy" data-copy-label>copy</span>
        </button>
        <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noopener">View source</a>
      </div>
      <p class="hero-meta">
        free forever · AGPL-3.0 · <a href="#download">macOS · Linux · Windows</a>
      </p>
    </div>

    <div class="hero-visual">
      <TerminalDemo />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(128px, 9vw + 40px, 168px);
    padding-bottom: clamp(72px, 7vw, 96px);
    overflow: clip;
  }

  /* the one ember in the room, breathing slowly */
  .hero::before {
    content: '';
    position: absolute;
    inset: -12% -8% 0;
    pointer-events: none;
    background: radial-gradient(44% 38% at 64% 24%, rgba(255, 122, 24, 0.11), transparent 64%);
    animation: breathe 13s ease-in-out infinite alternate;
    z-index: 0;
  }

  /* fine workbench grid, fading in around the terminal */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(230, 235, 245, 0.07) 1px, transparent 1.3px);
    background-size: 27px 27px;
    -webkit-mask-image: radial-gradient(56% 64% at 66% 40%, #000 20%, transparent 74%);
    mask-image: radial-gradient(56% 64% at 66% 40%, #000 20%, transparent 74%);
    z-index: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 30fr) minmax(0, 34fr);
    gap: 64px;
    align-items: center;
  }

  .hero-h {
    /* sized so the longest beat ("Your terminal.", 14ch) holds one line
       at every width — three tight lines, never four */
    font-size: clamp(38px, 4.9vw, 56px);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
  }

  .h-flame {
    background: linear-gradient(98deg, var(--gold) 8%, var(--ember) 55%, var(--flame) 96%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-sub {
    margin-top: 28px;
    color: var(--ash);
    font-size: 18px;
    max-width: 52ch;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 40px;
  }

  /* the command owns its row — the whole column is its stage */
  .hero-ctas :global(.install-cmd) {
    width: 100%;
  }

  .hero-meta {
    margin-top: 26px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ash);
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .hero-meta {
      white-space: normal;
    }
  }

  .hero-meta a {
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--bar);
  }

  .hero-meta a:hover {
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .hero {
      padding-top: 132px;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 56px;
    }

    .hero-sub {
      max-width: 62ch;
    }
  }
</style>

