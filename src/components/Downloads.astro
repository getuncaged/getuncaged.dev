---
import { SITE, DOWNLOADS } from '../data/site';

const { macos, linux, windows } = DOWNLOADS;
const quarantineCmd = 'xattr -dr com.apple.quarantine /Applications/Uncaged.app';

// One uniform shape for every OS: a bordered list of format rows (each row a
// format label + subtitle on the left and architecture download chips on the
// right, the recommended arch `primary`), then a "terminal" stack of copy-able
// one-liners. `install` is the recommended, accented command (macOS: a curl
// installer that sidesteps Gatekeeper entirely — curl never sets the quarantine
// flag). `curl` is a plain download; `pm` a package manager; `note` a caption;
// `caveat` the labelled macOS Gatekeeper block for the .dmg path.
const installUrl = 'https://getuncaged.dev/install.sh';
const columns = [
  {
    id: 'mac',
    name: 'macOS',
    icon: 'apple',
    formats: [
      {
        label: '.dmg',
        sub: `macOS 10.14+ · v${SITE.version}`,
        arches: [
          { name: 'Apple Silicon', href: macos.primary.href, primary: true },
          { name: 'Intel', href: macos.others[0].href },
        ],
      },
    ],
    install: {
      label: 'install',
      hint: 'installs to /Applications and opens instantly — no Gatekeeper prompt',
      cmd: `curl -fsSL ${installUrl} | bash`,
    },
    pm: { label: 'Homebrew', cmd: macos.brew.cmd },
    caveat: {
      label: 'first launch · .dmg only',
      text: 'the one-liner above skips this; only the .dmg needs it',
      cmd: quarantineCmd,
    },
  },
  {
    id: 'linux',
    name: 'Linux',
    icon: 'linux',
    formats: [
      { label: '.deb', sub: 'Debian · Ubuntu', arches: [{ name: 'x64', href: linux.others[0].href, primary: true }] },
      { label: '.rpm', sub: 'Fedora · RHEL · SUSE', arches: [{ name: 'x64', href: linux.others[1].href }] },
      { label: 'AppImage', sub: 'any distro', arches: [{ name: 'x64', href: linux.others[2].href }] },
      { label: '.tar.gz', sub: 'any distro', arches: [{ name: 'x64', href: linux.primary.href }] },
    ],
    curl: `curl -LO ${linux.primary.href}`,
    note: 'arm64 builds are on the way.',
  },
  {
    id: 'windows',
    name: 'Windows',
    icon: 'windows',
    formats: [
      {
        label: '.exe',
        sub: 'Windows 11 / 10',
        arches: [
          { name: 'x64', href: windows.primary.href, primary: true },
          { name: 'ARM64', href: windows.others[0].href },
        ],
      },
    ],
    curl: `curl -LO ${windows.primary.href}`,
    pm: { label: 'winget', cmd: windows.winget.cmd },
  },
];
---

<section id="download">
  <div class="container dl-wrap">
    <div class="sec-head dl-head">
      <p class="eyebrow dl-eyebrow">04 · install</p>
      <h2 class="section-h">Get Uncaged.</h2>
      <p class="section-sub">
        macOS, Linux and Windows — free and open source. No accounts, no license keys, nothing to
        activate.
      </p>
    </div>

    <div class="dl-grid">
      {columns.map((col) => (
        <div class="dl-os">
          <div class="dl-os-head">
            {col.icon === 'apple' && (
              <svg class="os-ico" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16.4 12.8c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.9-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.3 1.2 9.7.8 1.2 1.8 2.5 3.1 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.6-1-2.7-3.7zM14 5.6c.7-.8 1.1-1.9 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4z"></path>
              </svg>
            )}
            {col.icon === 'linux' && (
              <svg class="os-ico os-ico-tux" width="18" height="21" viewBox="0 0 40 46" fill="currentColor" aria-hidden="true">
                <path d="M35.6386 34.654C34.466 34.1737 33.9645 33.5365 34.013 32.5856C34.0629 31.4757 33.4332 30.6627 33.1342 30.3415C33.3149 29.6514 33.8428 27.2641 33.1347 25.1905C32.3738 22.971 30.0507 19.5811 27.6537 16.2489C26.6724 14.8805 26.626 13.393 26.5724 11.6706C26.521 10.0278 26.463 8.16567 25.5469 6.0956C24.5508 3.84159 22.552 2.54907 20.0628 2.54907C18.5821 2.54907 17.0621 3.01186 15.8924 3.81865C13.4972 5.47169 13.8138 9.07577 14.0233 11.4606C14.052 11.7872 14.079 12.0957 14.0948 12.359C14.2343 14.6947 14.1074 15.9258 13.9414 16.2999C13.834 16.5444 13.3054 17.2403 12.746 17.9771C12.1675 18.739 11.5116 19.6027 10.9739 20.4076C10.3325 21.376 9.81461 22.8562 9.3138 24.2877C8.94738 25.3352 8.60127 26.3246 8.26434 26.9159C7.62576 28.0533 7.78465 29.1139 7.91732 29.6041C7.67557 29.772 7.32632 30.1027 7.03148 30.7259C6.67515 31.4863 5.95213 31.895 4.44867 32.184C3.75777 32.3254 3.28135 32.6159 3.03226 33.0475C2.66977 33.6756 2.86721 34.4648 3.04734 35.0041C3.31347 35.797 3.14763 36.2989 2.8461 37.21C2.77662 37.4203 2.69783 37.6584 2.61799 37.921C2.49226 38.3354 2.53762 38.7122 2.7525 39.0408C3.32029 39.9089 4.97714 40.215 6.68275 40.4163C7.70114 40.5372 8.81575 40.9445 9.89379 41.3386C10.9501 41.7246 12.0423 42.1238 13.0351 42.2449C13.186 42.2639 13.3354 42.2735 13.4795 42.2735C14.9785 42.2735 15.6558 41.2788 15.8705 40.8702C16.4089 40.7603 18.266 40.4085 20.1799 40.3613C22.0908 40.3067 23.9397 40.684 24.4635 40.8014C24.6282 41.1165 25.0622 41.8364 25.7542 42.2073C26.1345 42.4152 26.6637 42.5344 27.2058 42.5344H27.206C27.7849 42.5344 28.8863 42.3975 29.758 41.4805C30.6274 40.5591 32.7998 39.3829 34.3861 38.524C34.74 38.3324 35.0712 38.153 35.3616 37.9911C36.2527 37.4971 36.7389 36.7913 36.6955 36.0546C36.6594 35.4428 36.2544 34.9061 35.6386 34.654ZM15.9119 34.4766C15.801 33.6952 14.7959 32.9203 13.6319 32.023C12.6801 31.2893 11.6012 30.4577 11.304 29.7534C10.6898 28.3006 11.174 25.746 12.0181 24.4305C12.4353 23.7718 12.776 22.773 13.1056 21.807C13.4614 20.764 13.8294 19.6856 14.2409 19.2135C14.8926 18.4764 15.4949 17.0423 15.6016 15.9121C16.2119 16.4947 17.1586 17.234 18.0332 17.234C18.1678 17.234 18.2985 17.2164 18.4234 17.1812C19.0218 17.0084 19.9019 16.4998 20.753 16.0082C21.4867 15.5842 22.3916 15.0614 22.732 15.0138C23.3158 15.8521 26.7081 23.359 27.0547 25.7698C27.3289 27.6773 27.0392 29.2542 26.8936 29.8718C26.7764 29.8558 26.6366 29.8428 26.4898 29.8428C25.5449 29.8428 25.2948 30.3586 25.2296 30.6665C25.0621 31.4666 25.0444 34.0251 25.0426 34.5999C24.7009 35.034 22.9731 37.0781 20.4926 37.4456C19.4822 37.5924 18.5387 37.6669 17.6884 37.6669C16.9615 37.6669 16.4977 37.6108 16.3051 37.5816L15.0586 36.1553C15.5501 35.9127 16.0415 35.4006 15.9119 34.4766ZM17.4937 10.959C17.4547 10.9758 17.4165 10.9938 17.3788 11.0129C17.375 10.9285 17.3662 10.8429 17.3527 10.757C17.2167 9.97367 16.6972 9.40509 16.1179 9.40509C16.075 9.40509 16.0319 9.40837 15.9846 9.41558C15.6399 9.473 15.3696 9.73193 15.2214 10.099C15.3514 9.29353 15.8077 8.69715 16.3492 8.69715C16.985 8.69715 17.5221 9.55402 17.5221 10.5682C17.5221 10.696 17.5128 10.8232 17.4937 10.959ZM22.4343 11.563C22.4925 11.3776 22.524 11.177 22.524 10.9689C22.524 10.0493 21.9406 9.32892 21.1958 9.32892C20.4679 9.32892 19.8758 10.0645 19.8758 10.9689C19.8758 11.0305 19.8788 11.0922 19.8845 11.1538C19.846 11.139 19.8084 11.1246 19.7717 11.1107C19.6879 10.857 19.6456 10.5923 19.6456 10.3221C19.6456 9.2226 20.3482 8.32797 21.2122 8.32797C22.076 8.32797 22.7788 9.2226 22.7788 10.3221C22.7788 10.7795 22.6526 11.2161 22.4343 11.563ZM21.7973 13.7031C21.7848 13.7587 21.7584 13.7833 21.4655 13.9357C21.3176 14.0126 21.1335 14.1084 20.9032 14.2487L20.7493 14.3419C20.1308 14.7169 18.6825 15.5951 18.2893 15.6466C18.0223 15.6826 17.8571 15.579 17.4857 15.3266C17.4019 15.2696 17.3128 15.209 17.2177 15.1481C16.5482 14.7088 16.1175 14.2249 16.0689 14.0357C16.2872 13.867 16.8282 13.4447 17.1052 13.1947C17.6675 12.6718 18.2333 12.3205 18.5134 12.3205C18.5282 12.3205 18.5416 12.3215 18.5555 12.3242C18.8845 12.3822 19.6962 12.7062 20.289 12.9427C20.563 13.052 20.7996 13.1464 20.9661 13.2062C21.4907 13.3863 21.7641 13.6168 21.7973 13.7031ZM26.51 38.1362C26.8059 36.8015 27.1467 34.9858 27.0915 33.9153C27.0788 33.6721 27.0573 33.4075 27.0365 33.1515C26.9975 32.673 26.9397 31.9618 26.9994 31.7509C27.0112 31.7454 27.0243 31.7406 27.0388 31.7366C27.0413 32.3486 27.1742 33.5692 28.1504 33.9949C28.4413 34.1218 28.7738 34.1861 29.1385 34.1861C30.1164 34.1861 31.2014 33.7064 31.6458 33.2619C31.9075 33.0003 32.1276 32.6801 32.2818 32.4266C32.3155 32.5253 32.3362 32.6543 32.3253 32.8205C32.2672 33.7231 32.7059 34.9206 33.5407 35.3619L33.6623 35.4257C33.9596 35.5818 34.7494 35.9964 34.7621 36.1931C34.7621 36.1931 34.7554 36.2163 34.7113 36.2572C34.5135 36.438 33.8172 36.7935 33.1439 37.1374C31.9494 37.7473 30.5956 38.4386 29.9875 39.0781C29.1314 39.979 28.1631 40.5841 27.5784 40.5841C27.508 40.5841 27.4439 40.5752 27.3869 40.5571C26.7518 40.3592 26.2291 39.4429 26.51 38.1362ZM4.86386 34.7312C4.7991 34.4281 4.74797 34.1888 4.8029 33.957C4.84276 33.7853 5.69058 33.6012 6.05268 33.5227C6.56174 33.4122 7.08824 33.298 7.43251 33.089C7.89805 32.807 8.15016 32.2869 8.3725 31.8281C8.53349 31.4963 8.69973 31.1532 8.89756 31.0406C8.9087 31.034 8.92575 31.0264 8.95826 31.0264C9.32888 31.0264 10.1066 31.8055 10.5547 32.5029C10.6683 32.6787 10.8789 33.0309 11.1225 33.4388C11.851 34.6578 12.8485 36.3273 13.3695 36.8869C13.839 37.3899 14.599 38.357 14.412 39.1865C14.2752 39.8301 13.5465 40.3534 13.3746 40.4692C13.3122 40.4833 13.235 40.4905 13.1442 40.4905C12.147 40.4905 10.1732 39.6609 9.11269 39.2152L8.95577 39.1493C8.36359 38.901 7.39685 38.7445 6.46198 38.5933C5.71811 38.4728 4.69947 38.308 4.53061 38.1591C4.39374 38.0055 4.5525 37.5064 4.69252 37.0661C4.79333 36.7496 4.89743 36.4224 4.95446 36.0798C5.03534 35.5334 4.94017 35.0886 4.86386 34.7312Z"></path>
              </svg>
            )}
            {col.icon === 'windows' && (
              <svg class="os-ico" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3 5.5L10.5 4.4V11.5H3V5.5ZM3 18.5L10.5 19.6V12.5H3V18.5ZM11.5 19.8L21 21V12.5H11.5V19.8ZM11.5 4.2V11.5H21V3L11.5 4.2Z"></path>
              </svg>
            )}
            <h3>{col.name}</h3>
          </div>

          <div class="dl-list">
            {col.formats.map((f) => (
              <div class="dl-row">
                <div class="dl-row-info">
                  <span class="dl-row-label">{f.label}</span>
                  <span class="dl-row-sub">{f.sub}</span>
                </div>
                <div class="dl-archs">
                  {f.arches.map((a) => (
                    <a class:list={['dl-chip', a.primary && 'is-primary']} href={a.href} aria-label={`Download ${col.name} ${f.label} for ${a.name}`}>
                      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M8 2.75v7"></path>
                        <path d="M4.75 6.75 8 10l3.25-3.25"></path>
                        <path d="M3 13.25h10"></path>
                      </svg>
                      {a.name}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div class="dl-term">
            {col.install && (
              <div class="dl-cmd-group is-primary">
                <span class="dl-cmd-label">{col.install.label}</span>
                <span class="dl-cmd-hint">{col.install.hint}</span>
                <div class="dl-cmd">
                  <code><span class="dl-cmd-p">$</span>{col.install.cmd}</code>
                  <button class="copy-btn" type="button" data-copy={col.install.cmd} aria-label={`Copy the ${col.name} install command`}>copy</button>
                </div>
              </div>
            )}

            {col.curl && (
              <div class="dl-cmd-group">
                <span class="dl-cmd-label">curl</span>
                <div class="dl-cmd">
                  <code><span class="dl-cmd-p">$</span>{col.curl}</code>
                  <button class="copy-btn" type="button" data-copy={col.curl} aria-label={`Copy the ${col.name} curl download command`}>copy</button>
                </div>
              </div>
            )}

            {col.pm && (
              <div class="dl-cmd-group">
                <span class="dl-cmd-label">{col.pm.label}</span>
                <div class="dl-cmd">
                  <code><span class="dl-cmd-p">$</span>{col.pm.cmd}</code>
                  <button class="copy-btn" type="button" data-copy={col.pm.cmd} aria-label={`Copy the ${col.pm.label} install command`}>copy</button>
                </div>
              </div>
            )}

            {col.caveat && (
              <div class="dl-cmd-group dl-cmd-caveat">
                <span class="dl-cmd-label">{col.caveat.label}</span>
                <span class="dl-cmd-hint">{col.caveat.text}</span>
                <div class="dl-cmd">
                  <code><span class="dl-cmd-p">$</span>{col.caveat.cmd}</code>
                  <button class="copy-btn" type="button" data-copy={col.caveat.cmd} aria-label="Copy the clear-quarantine command">copy</button>
                </div>
              </div>
            )}

            {col.note && <p class="dl-note">{col.note}</p>}
          </div>
        </div>
      ))}
    </div>

    <p class="dl-foot">
      Every build is on the
      <a href={SITE.releases} target="_blank" rel="noopener">releases page</a>
      — checksums, changelogs and older versions.
    </p>
  </div>
</section>

<style>
  .dl-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dl-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 60px;
  }

  .dl-eyebrow {
    justify-content: center;
  }

  .dl-head .section-h {
    max-width: none;
  }

  .dl-head .section-sub {
    max-width: 52ch;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    width: 100%;
    margin-bottom: 44px;
  }

  .dl-os {
    display: flex;
    flex-direction: column;
    padding: 4px 36px;
  }

  .dl-os:first-child {
    padding-left: 0;
  }

  .dl-os:last-child {
    padding-right: 0;
  }

  .dl-os + .dl-os {
    border-left: 1px solid var(--bar);
  }

  .dl-os-head {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .os-ico {
    flex-shrink: 0;
  }

  .dl-os-head h3 {
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* the bordered list of format rows */
  .dl-list {
    border: 1px solid var(--bar);
    border-radius: var(--radius);
    background: var(--panel);
    overflow: hidden;
  }

  .dl-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 13px 15px;
  }

  .dl-row + .dl-row {
    border-top: 1px solid var(--line-soft);
  }

  .dl-row-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .dl-row-label {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .dl-row-sub {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
    white-space: nowrap;
  }

  .dl-archs {
    display: flex;
    gap: 7px;
    flex-shrink: 0;
  }

  /* architecture download chip — the action */
  .dl-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 11px;
    border: 1px solid var(--bar);
    border-radius: var(--radius-s);
    background: var(--raised);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--ash);
    white-space: nowrap;
    transition:
      color 0.14s ease,
      border-color 0.14s ease,
      background 0.14s ease,
      transform 0.14s ease;
  }

  .dl-chip svg {
    opacity: 0.7;
    transition: opacity 0.14s ease;
  }

  .dl-chip:hover {
    color: var(--ink);
    border-color: var(--muted);
    transform: translateY(-1px);
  }

  .dl-chip:hover svg {
    opacity: 1;
  }

  /* recommended architecture — the one warm action in the section */
  .dl-chip.is-primary {
    color: #16100a;
    background: linear-gradient(180deg, var(--gold), var(--ember));
    border-color: transparent;
    box-shadow: 0 6px 20px -8px rgba(255, 122, 24, 0.55);
  }

  .dl-chip.is-primary svg {
    opacity: 0.85;
  }

  .dl-chip.is-primary:hover {
    color: #16100a;
    filter: brightness(1.06);
    box-shadow: 0 8px 24px -8px rgba(255, 122, 24, 0.7);
  }

  /* terminal stack: curl download + package manager + Gatekeeper caveat */
  .dl-term {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dl-cmd-label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    padding-left: 2px;
  }

  .dl-cmd-hint {
    display: block;
    font-size: 12px;
    color: var(--ash);
    margin: -3px 0 8px;
    padding-left: 2px;
  }

  .dl-cmd {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #151311;
    border: 1px solid var(--bar);
    border-radius: var(--radius-s);
    padding: 10px 10px 10px 13px;
  }

  .dl-cmd code {
    flex: 1;
    min-width: 0;
    font-family: var(--mono);
    font-size: 11.5px;
    line-height: 1.55;
    color: var(--ink);
    white-space: normal;
    overflow-wrap: break-word;
  }

  .dl-cmd-p {
    color: var(--ember);
    font-weight: 700;
    user-select: none;
    margin-right: 8px;
  }

  /* keep the copy button beside the command (never overlapping it) */
  .dl-cmd .copy-btn {
    position: static;
    flex-shrink: 0;
  }

  /* recommended install — the one warm, emphasised path in the column */
  .dl-cmd-group.is-primary .dl-cmd-label {
    color: var(--ember);
  }

  .dl-cmd-group.is-primary .dl-cmd {
    border-color: rgba(255, 122, 24, 0.45);
    background: linear-gradient(180deg, rgba(255, 122, 24, 0.06), #151311 60%);
    box-shadow: 0 8px 26px -14px rgba(255, 122, 24, 0.6);
  }

  /* Gatekeeper caveat — a warm accent marks it as a caution, not an install */
  .dl-cmd-caveat .dl-cmd-label {
    color: var(--gold);
  }

  /* Linux has no package manager yet — a plain, honest note */
  .dl-note {
    margin: 0;
    padding-left: 2px;
    font-size: 12.5px;
    color: var(--muted);
  }

  /* single shared footnote under the whole grid */
  .dl-foot {
    text-align: center;
    font-size: 13px;
    color: var(--muted);
    max-width: 72ch;
  }

  .dl-foot a {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--bar);
    white-space: nowrap;
  }

  .dl-foot a:hover {
    color: var(--ember);
    text-decoration-color: var(--ember);
