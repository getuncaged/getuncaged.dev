---
import { SITE } from '../data/site';

const quarantineCmd = 'xattr -dr com.apple.quarantine /Applications/Uncaged.app';
const curlCmd = `curl -LO ${SITE.dmg}`;
---

<section id="download">
  <div class="container dl-wrap">
    <div class="sec-head dl-head">
      <p class="eyebrow dl-eyebrow">04 · install</p>
      <h2 class="section-h">Get Uncaged.</h2>
      <p class="section-sub">
        Free and open source. No installer accounts, no license keys, nothing to activate.
      </p>
    </div>

    <div class="dl-primary">
      <a class="btn btn-primary dl-btn" href={SITE.dmg}>
        <svg width="17" height="17" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8 2.75v7"></path>
          <path d="M4.75 6.75 8 10l3.25-3.25"></path>
          <path d="M3 13.25h10"></path>
        </svg>
        Download for macOS
      </a>
      <p class="dl-meta">v{SITE.version} · Apple Silicon · .dmg · AGPL-3.0</p>
      <div class="codeblock dl-curl">
        <pre><span class="prompt">❯</span> {curlCmd}</pre>
        <button class="copy-btn" data-copy={curlCmd} aria-label="Copy download command">copy</button>
      </div>
    </div>

    <ol class="dl-steps">
      <li>
        <span class="dl-n" aria-hidden="true">1</span>
        <h3>Drag to Applications</h3>
        <p>Open the .dmg and drop Uncaged into Applications.</p>
      </li>
      <li>
        <span class="dl-n" aria-hidden="true">2</span>
        <h3>Clear quarantine, once</h3>
        <p>The app is ad-hoc signed — an independent fork has no Apple Developer ID.</p>
        <div class="codeblock dl-cmd">
          <pre><span class="prompt">❯</span> {quarantineCmd}</pre>
          <button class="copy-btn" data-copy={quarantineCmd} aria-label="Copy quarantine command">copy</button>
        </div>
      </li>
      <li>
        <span class="dl-n" aria-hidden="true">3</span>
        <h3>Connect a model</h3>
        <p>Open <span class="dl-kbd">Settings → AI Models</span> and pick one. The agent is live.</p>
      </li>
    </ol>

    <p class="dl-others">
      Linux <b>in the works</b> · Windows <b>planned</b> ·
      <a href={SITE.github} target="_blank" rel="noopener">build from source →</a> ·
      <a href={SITE.releases} target="_blank" rel="noopener">all releases →</a>
    </p>
  </div>
</section>

<style>
  .dl-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dl-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 56px;
  }

  .dl-eyebrow {
    justify-content: center;
  }

  .dl-head .section-h {
    max-width: none;
  }

  .dl-head .section-sub {
    max-width: 46ch;
  }

  .dl-primary {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-bottom: 88px;
  }

  .dl-btn {
    padding: 19px 34px;
    font-size: 15.5px;
    border-radius: 12px;
  }

  .dl-meta {
    margin-top: 16px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted, #5d6577);
  }

  /* copy button as a right cap — never overlaps the command */
  .dl-curl,
  .dl-cmd {
    display: flex;
    align-items: stretch;
  }

  .dl-curl pre,
  .dl-cmd pre {
    flex: 1;
    min-width: 0;
    padding-right: 14px;
    -webkit-mask-image: linear-gradient(90deg, #000 calc(100% - 36px), transparent);
    mask-image: linear-gradient(90deg, #000 calc(100% - 36px), transparent);
  }

  .dl-curl :global(.copy-btn),
  .dl-cmd :global(.copy-btn) {
    position: static;
    flex-shrink: 0;
    border: 0;
    border-left: 1px solid var(--bar);
    border-radius: 0;
    padding: 0 14px;
  }

  .dl-curl {
    margin-top: 22px;
    width: 100%;
    max-width: 660px;
  }

  .dl-curl pre {
    font-size: 12px;
    padding-block: 13px;
  }

  .dl-steps {
    list-style: none;
    margin: 0 0 72px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 48px;
    width: 100%;
    align-items: start;
  }

  .dl-steps li {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-top: 1px solid var(--bar);
    padding-top: 26px;
  }

  .dl-n {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--ember);
    border: 1px solid rgba(255, 122, 24, 0.35);
    border-radius: 999px;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }

  .dl-steps h3 {
    font-size: 15.5px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .dl-steps p {
    color: var(--ash);
    font-size: 14.5px;
    line-height: 1.6;
    max-width: 36ch;
  }

  .dl-kbd {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink);
    background: var(--panel);
    border: 1px solid var(--bar);
    border-radius: 6px;
    padding: 1.5px 7px;
    white-space: nowrap;
  }

  .dl-cmd {
    margin-top: 14px;
    width: 100%;
  }

  .dl-cmd pre {
    font-size: 10.5px;
    padding-block: 12px;
  }

  .dl-others {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ash);
  }

  .dl-others b {
    color: var(--ink);
    font-weight: 500;
  }

  .dl-others a {
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--bar);
    transition: color var(--fast);
  }

  .dl-others a:hover {
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .dl-steps {
      grid-template-columns: minmax(0, 1fr);
      gap: 40px;
      margin-bottom: 56px;
    }

    .dl-primary {
      margin-bottom: 64px;
    }

    .dl-others {
      text-align: center;
      line-height: 2.2;
    }
  }
</style>
