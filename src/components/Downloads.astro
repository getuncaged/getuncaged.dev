---
import { SITE, DOWNLOADS } from '../data/site';

const { macos, linux, windows } = DOWNLOADS;
const quarantineCmd = 'xattr -dr com.apple.quarantine /Applications/Uncaged.app';

// One uniform shape for every OS: a bordered list of format rows, each row a
// format label + subtitle on the left and one or more architecture download
// chips on the right (the recommended arch is `primary`). A single muted
// footer line per column previews the not-yet-live channel — the install
// command names its own tool, so no separate label (`cmd`), or a plain `note`.
const columns = [
  {
    id: 'mac',
    name: 'macOS',
    icon: 'apple',
    formats: [
      {
        label: '.dmg',
        sub: `macOS 10.14+ · v${SITE.version}`,
        arches: [
          { name: 'Apple Silicon', href: macos.primary.href, primary: true },
          { name: 'Intel', href: macos.others[0].href },
        ],
      },
    ],
    soon: { cmd: macos.brew.cmd },
  },
  {
    id: 'linux',
    name: 'Linux',
    icon: 'linux',
    formats: [
      { label: '.deb', sub: 'Debian · Ubuntu', arches: [{ name: 'x64', href: linux.others[0].href, primary: true }] },
      { label: '.rpm', sub: 'Fedora · RHEL · SUSE', arches: [{ name: 'x64', href: linux.others[1].href }] },
      { label: 'AppImage', sub: 'any distro', arches: [{ name: 'x64', href: linux.others[2].href }] },
      { label: '.tar.gz', sub: 'any distro', arches: [{ name: 'x64', href: linux.primary.href }] },
    ],
    soon: { note: 'arm64 builds are on the way' },
  },
  {
    id: 'windows',
    name: 'Windows',
    icon: 'windows',
    formats: [
      {
        label: '.exe',
        sub: 'Windows 11 / 10',
        arches: [
          { name: 'x64', href: windows.primary.href, primary: true },
          { name: 'ARM64', href: windows.others[0].href },
        ],
      },
    ],
    soon: { cmd: windows.winget.cmd },
  },
];
---

<section id="download">
  <div class="container dl-wrap">
    <div class="sec-head dl-head">
      <p class="eyebrow dl-eyebrow">04 · install</p>
      <h2 class="section-h">Get Uncaged.</h2>
      <p class="section-sub">
        macOS, Linux and Windows — free and open source. No accounts, no license keys, nothing to
        activate.
      </p>
    </div>

    <div class="dl-grid">
      {columns.map((col) => (
        <div class="dl-os">
          <div class="dl-os-head">
            {col.icon === 'apple' && (
              <svg class="os-ico" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16.4 12.8c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.9-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.3 1.2 9.7.8 1.2 1.8 2.5 3.1 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.6-1-2.7-3.7zM14 5.6c.7-.8 1.1-1.9 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4z"></path>
              </svg>
            )}
            {col.icon === 'linux' && (
              <svg class="os-ico os-ico-tux" width="21" height="21" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="currentColor"
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M12 1.9c-2.8 0-4.35 2.25-4.35 5.55 0 1.32-.34 2.32-.94 3.42-.52-.28-1.05-.36-1.53-.16-.83.35-1.1 1.4-.66 2.5.3.75.86 1.25 1.45 1.4-.36.86-.57 1.72-.57 2.54 0 3.06 3.04 5.05 7 5.05s7-1.99 7-5.05c0-.82-.2-1.68-.57-2.54.6-.15 1.15-.65 1.45-1.4.44-1.1.17-2.15-.66-2.5-.48-.2-1.01-.12-1.53.16-.6-1.1-.94-2.1-.94-3.42C16.35 4.15 14.8 1.9 12 1.9Zm0 8.35c-1.63 0-2.7 1.9-2.7 4.5 0 2.6 1.07 4.35 2.7 4.35s2.7-1.75 2.7-4.35c0-2.6-1.07-4.5-2.7-4.5Z"
                ></path>
                <circle fill="currentColor" cx="10.25" cy="6.7" r="0.95"></circle>
                <circle fill="currentColor" cx="13.75" cy="6.7" r="0.95"></circle>
                <path fill="var(--gold)" d="M10.75 7.7h2.5l-1.25 1.7z"></path>
                <path fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" d="M9.2 21.2c-.75.75-2 .85-2.75.15M14.8 21.2c.75.75 2 .85 2.75.15"></path>
              </svg>
            )}
            {col.icon === 'windows' && (
              <svg class="os-ico" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3 5.5L10.5 4.4V11.5H3V5.5ZM3 18.5L10.5 19.6V12.5H3V18.5ZM11.5 19.8L21 21V12.5H11.5V19.8ZM11.5 4.2V11.5H21V3L11.5 4.2Z"></path>
              </svg>
            )}
            <h3>{col.name}</h3>
          </div>

          <div class="dl-list">
            {col.formats.map((f) => (
              <div class="dl-row">
                <div class="dl-row-info">
                  <span class="dl-row-label">{f.label}</span>
                  <span class="dl-row-sub">{f.sub}</span>
                </div>
                <div class="dl-archs">
                  {f.arches.map((a) => (
                    <a class:list={['dl-chip', a.primary && 'is-primary']} href={a.href} aria-label={`Download ${col.name} ${f.label} for ${a.name}`}>
                      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M8 2.75v7"></path>
                        <path d="M4.75 6.75 8 10l3.25-3.25"></path>
                        <path d="M3 13.25h10"></path>
                      </svg>
                      {a.name}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <p class="dl-soon">
            <span class="dl-soon-tag">soon</span>
            {col.soon.cmd ? <code>{col.soon.cmd}</code> : <span class="dl-soon-note">{col.soon.note}</span>}
          </p>
        </div>
      ))}
    </div>

    <p class="dl-foot">
      macOS is ad-hoc signed — clear Gatekeeper once:
      <code>{quarantineCmd}</code>
      <a href={SITE.releases} target="_blank" rel="noopener">All releases &amp; checksums →</a>
    </p>
  </div>
</section>

<style>
  .dl-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dl-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 60px;
  }

  .dl-eyebrow {
    justify-content: center;
  }

  .dl-head .section-h {
    max-width: none;
  }

  .dl-head .section-sub {
    max-width: 52ch;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    width: 100%;
    margin-bottom: 44px;
  }

  .dl-os {
    display: flex;
    flex-direction: column;
    padding: 4px 36px;
  }

  .dl-os:first-child {
    padding-left: 0;
  }

  .dl-os:last-child {
    padding-right: 0;
  }

  .dl-os + .dl-os {
    border-left: 1px solid var(--bar);
  }

  .dl-os-head {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .os-ico {
    flex-shrink: 0;
  }

  .dl-os-head h3 {
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* the bordered list of format rows */
  .dl-list {
    border: 1px solid var(--bar);
    border-radius: var(--radius);
    background: var(--panel);
    overflow: hidden;
  }

  .dl-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 13px 15px;
  }

  .dl-row + .dl-row {
    border-top: 1px solid var(--line-soft);
  }

  .dl-row-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .dl-row-label {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .dl-row-sub {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
    white-space: nowrap;
  }

  .dl-archs {
    display: flex;
    gap: 7px;
    flex-shrink: 0;
  }

  /* architecture download chip — the action */
  .dl-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 11px;
    border: 1px solid var(--bar);
    border-radius: var(--radius-s);
    background: var(--raised);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--ash);
    white-space: nowrap;
    transition:
      color 0.14s ease,
      border-color 0.14s ease,
      background 0.14s ease,
      transform 0.14s ease;
  }

  .dl-chip svg {
    opacity: 0.7;
    transition: opacity 0.14s ease;
  }

  .dl-chip:hover {
    color: var(--ink);
    border-color: var(--muted);
    transform: translateY(-1px);
  }

  .dl-chip:hover svg {
    opacity: 1;
  }

  /* recommended architecture — the one warm action in the section */
  .dl-chip.is-primary {
    color: #16100a;
    background: linear-gradient(180deg, var(--gold), var(--ember));
    border-color: transparent;
    box-shadow: 0 6px 20px -8px rgba(255, 122, 24, 0.55);
  }

  .dl-chip.is-primary svg {
    opacity: 0.85;
  }

  .dl-chip.is-primary:hover {
    color: #16100a;
    filter: brightness(1.06);
    box-shadow: 0 8px 24px -8px rgba(255, 122, 24, 0.7);
  }

  /* not-yet-live channel, clearly de-emphasised */
  .dl-soon {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
    padding-left: 2px;
    font-size: 12.5px;
    color: var(--muted);
    min-height: 22px;
  }

  .dl-soon-tag {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--bar);
    border-radius: 5px;
    padding: 1.5px 6px;
  }

  .dl-soon-note {
    font-size: 12.5px;
    color: var(--ash);
  }

  .dl-soon code {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  /* single shared footnote under the whole grid */
  .dl-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 14px;
    text-align: center;
    font-size: 13px;
    color: var(--muted);
    max-width: 72ch;
  }

  .dl-foot code {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ash);
    background: var(--panel);
    border: 1px solid var(--bar);
    border-radius: 6px;
    padding: 3px 8px;
  }

  .dl-foot a {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--bar);
    white-space: nowrap;
  }

  .dl-foot a:hover {
    color: var(--ember);
    text-decoration-color: var(--ember);
  }

  @media (max-width: 980px) {
    .dl-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 40px;
    }

    .dl-os,
    .dl-os:first-child,
    .dl-os:last-child {
      padding: 0;
    }

    .dl-os + .dl-os {
      border-left: 0;
      border-top: 1px solid var(--bar);
      padding-top: 36px;
    }
  }

  @media (max-width: 460px) {
    .dl-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .dl-archs {
      width: 100%;
    }

    .dl-chip {
      flex: 1;
      justify-content: center;
    }
  }
</style>
