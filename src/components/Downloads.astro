---
import { SITE } from '../data/site';

const cloneCmd = `git clone ${SITE.github}.git`;
const curlCmd = `curl -LO ${SITE.dmg}`;
const quarantineCmd = 'xattr -dr com.apple.quarantine /Applications/Uncaged.app';
---

<section id="download">
  <div class="container">
    <div class="sec-head">
      <p class="eyebrow">04 · install</p>
      <h2 class="section-h">Get Uncaged.</h2>
      <p class="section-sub">
        Download it, curl it, or build it — whichever way you trust. No installer accounts, no
        license keys, nothing to activate.
      </p>
    </div>

    <div class="dl-grid">
      <!-- macOS — live -->
      <div class="dl-card dl-mac">
        <div class="dl-head">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M16.4 12.8c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.9-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.3 1.2 9.7.8 1.2 1.8 2.5 3.1 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.6-1-2.7-3.7zM14 5.6c.7-.8 1.1-1.9 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4z"
            ></path>
          </svg>
          <h3>macOS</h3>
          <span class="dl-tag dl-live">v{SITE.version}</span>
        </div>
        <p class="dl-blurb">Apple Silicon. Drag to Applications, clear quarantine once, done.</p>
        <a class="btn btn-primary dl-btn" href={SITE.dmg}>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1v9.3L4.9 7.2 3.8 8.3 8 12.5l4.2-4.2-1.1-1.1L8 10.3V1H8zM2 13.5h12V15H2v-1.5z"></path>
          </svg>
          Download Uncaged.dmg
        </a>

        <p class="dl-step">Ad-hoc signed — an independent fork has no Apple Developer ID. On first launch:</p>
        <div class="codeblock">
          <pre><span class="prompt">❯</span> {quarantineCmd}</pre>
          <button class="copy-btn" data-copy={quarantineCmd} aria-label="Copy quarantine command">copy</button>
        </div>

        <p class="dl-step">Prefer the terminal end to end:</p>
        <div class="codeblock">
          <pre><span class="prompt">❯</span> {curlCmd}</pre>
          <button class="copy-btn" data-copy={curlCmd} aria-label="Copy curl command">copy</button>
        </div>
      </div>

      <div class="dl-side">
        <!-- Linux -->
        <div class="dl-card">
          <div class="dl-head">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 4.5C9 3 10.2 2 12 2s3 1 3 2.5c0 2.5 1 3.5 2.5 5.5 1.3 1.8 2 3.5 2 5.5 0 1.4-.6 2.6-1.5 3.5M4.5 19c-.9-.9-1.5-2.1-1.5-3.5 0-2 .7-3.7 2-5.5C6.5 8 7.5 7 7.5 4.5"></path>
              <path d="M8.5 21c-1.5 0-2.5-1-4-2M15.5 21c1.5 0 2.5-1 4-2"></path>
              <path d="M9.5 9.5h.01M14.5 9.5h.01M10 13c.6.7 1.2 1 2 1s1.4-.3 2-1"></path>
            </svg>
            <h3>Linux</h3>
            <span class="dl-tag">in the works</span>
          </div>
          <p class="dl-blurb">
            The client already builds on Linux upstream; the Uncaged release pipeline is next. Until
            then it compiles from source.
          </p>
          <a class="dl-watch" href={SITE.releases} target="_blank" rel="noopener">Watch releases →</a>
        </div>

        <!-- Windows -->
        <div class="dl-card">
          <div class="dl-head">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 5.5L10.5 4.4V11.5H3V5.5ZM3 18.5L10.5 19.6V12.5H3V18.5ZM11.5 19.8L21 21V12.5H11.5V19.8ZM11.5 4.2V11.5H21V3L11.5 4.2Z"></path>
            </svg>
            <h3>Windows</h3>
            <span class="dl-tag">on the bench</span>
          </div>
          <p class="dl-blurb">
            Tracked alongside upstream's Windows target. Follow the repo to hear when it lands.
          </p>
          <a class="dl-watch" href={SITE.releases} target="_blank" rel="noopener">Watch releases →</a>
        </div>

        <!-- Source -->
        <div class="dl-card">
          <div class="dl-head">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 6.5L3.5 12 8 17.5M16 6.5l4.5 5.5-4.5 5.5M13.5 4l-3 16"></path>
            </svg>
            <h3>Source</h3>
            <span class="dl-tag">always</span>
          </div>
          <div class="codeblock dl-clone">
            <pre><span class="prompt">❯</span> {cloneCmd}</pre>
            <button class="copy-btn" data-copy={cloneCmd} aria-label="Copy clone command">copy</button>
          </div>
          <a class="dl-watch" href={SITE.releases} target="_blank" rel="noopener">All releases &amp; checksums →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sec-head {
    margin-bottom: 56px;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
    gap: 18px;
    align-items: start;
  }

  .dl-card {
    background: var(--panel);
    border: 1px solid var(--bar);
    border-radius: var(--radius-l);
    padding: 26px;
  }

  .dl-mac {
    border-color: #4d3e2d;
    background: linear-gradient(180deg, var(--raised), var(--panel));
  }

  .dl-side {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 18px;
  }

  .dl-head {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .dl-head h3 {
    font-size: 16px;
    font-weight: 700;
    flex: 1;
  }

  .dl-tag {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 500;
    color: var(--ash);
    border: 1px solid var(--bar);
    border-radius: 999px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .dl-live {
    color: var(--void);
    background: var(--ember);
    border-color: var(--ember);
    font-weight: 700;
  }

  .dl-blurb {
    color: var(--ash);
    font-size: 14.5px;
    line-height: 1.6;
  }

  .dl-btn {
    width: 100%;
    margin-top: 18px;
  }

  .dl-step {
    font-family: var(--mono);
    font-size: 11.5px;
    color: #6d6455;
    margin: 20px 0 8px;
  }

  .dl-watch {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ash);
    transition: color var(--fast);
  }

  .dl-watch:hover {
    color: var(--ink);
  }

  .dl-clone {
    margin-top: 4px;
  }

  .dl-clone pre {
    font-size: 12px;
  }

  @media (max-width: 900px) {
    .dl-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
