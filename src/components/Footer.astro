---
import Logo from './Logo.astro';
import { SITE } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="#top" class="foot-logo" aria-label="Back to top">
          <Logo idp="foot" size={26} />
          <span>uncaged</span>
        </a>
        <p class="foot-tag">
          The open-source Warp terminal with the cloud removed. Your models, your keys, your
          machine.
        </p>
        <p class="foot-handle">{SITE.handle}</p>
      </div>

      <nav class="foot-col" aria-label="Product">
        <h4>product</h4>
        <a href="#privacy">privacy</a>
        <a href="#models">models</a>
        <a href="#open-source">fork it</a>
        <a href="#download">download</a>
        <a href="#faq">faq</a>
      </nav>

      <nav class="foot-col" aria-label="Source">
        <h4>source</h4>
        <a href={SITE.github} target="_blank" rel="noopener">github</a>
        <a href={SITE.releases} target="_blank" rel="noopener">releases</a>
        <a href={SITE.issues} target="_blank" rel="noopener">issues</a>
        <a href={`${SITE.github}/blob/master/LICENSE-AGPL`} target="_blank" rel="noopener">license · AGPL-3.0</a>
      </nav>

      <nav class="foot-col" aria-label="Docs">
        <h4>docs</h4>
        <a href={SITE.uncagedDoc} target="_blank" rel="noopener">connect a model</a>
        <a href={SITE.migrateDoc} target="_blank" rel="noopener">migrate from warp</a>
        <a href={`${SITE.github}/blob/master/FORKING.md`} target="_blank" rel="noopener">fork &amp; rebrand</a>
        <a href={`${SITE.github}/blob/master/CONTRIBUTING.md`} target="_blank" rel="noopener">contributing</a>
      </nav>
    </div>

    <div class="foot-bottom">
      <p>© {year} Uncaged contributors · AGPL-3.0</p>
      <p class="foot-legal">
        Uncaged is an independent community fork of the open-source Warp client (© Denver
        Technologies, Inc.). Not affiliated with or endorsed by Warp.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--bar);
    padding: 72px 0 40px;
    background: linear-gradient(180deg, var(--void), #08090d);
  }

  .foot-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) repeat(3, minmax(0, 1fr));
    gap: 48px;
  }

  .foot-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 16px;
    color: var(--ink);
  }

  .foot-tag {
    margin-top: 16px;
    color: var(--ash);
    font-size: 14.5px;
    max-width: 34ch;
  }

  .foot-handle {
    margin-top: 14px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted, #5d6577);
  }

  .foot-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .foot-col h4 {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted, #5d6577);
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .foot-col a {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ash);
    transition: color var(--fast);
    width: fit-content;
  }

  .foot-col a:hover {
    color: var(--ink);
  }

  .foot-bottom {
    margin-top: 64px;
    padding-top: 26px;
    border-top: 1px solid rgba(60, 67, 82, 0.5);
    display: flex;
    justify-content: space-between;
    gap: 24px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted, #5d6577);
  }

  .foot-legal {
    max-width: 62ch;
    text-align: right;
  }

  @media (max-width: 900px) {
    .foot-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .foot-bottom {
      flex-direction: column;
    }

    .foot-legal {
      text-align: left;
    }
  }
</style>
