---
import { AUDIT, SITE } from '../data/site';
---

<section id="privacy">
  <div class="container">
    <div class="sec-head">
      <p class="eyebrow">01 · no cloud</p>
      <h2 class="section-h">Zero telemetry. One outbound call.</h2>
      <p class="section-sub">
        The only network request Uncaged ever makes is the one to your model endpoint. Accounts,
        telemetry, crash reporting, cloud sync — none of it exists in this build. The source is
        public, so you can verify that instead of trusting it.
      </p>
    </div>

    <div class="priv-grid">
      <div class="priv-left">
        <div class="wire">
          <div class="wire-machine">
            <div class="wire-machine-head">
              <span>your machine</span>
            </div>
            <ul>
              <li>uncaged + uncaged_engine</li>
              <li>keys · history · config</li>
              <li><code>~/.uncaged/</code></li>
            </ul>
          </div>
          <div class="wire-arrow" aria-hidden="true">
            <span class="wire-label">the only outbound call</span>
            <span class="wire-line"><i class="wire-pulse"></i></span>
          </div>
          <div class="wire-endpoint">the endpoint <br />you chose</div>
        </div>
        <a class="btn btn-ghost btn-small priv-btn" href={SITE.github} target="_blank" rel="noopener">
          Read the code
        </a>
      </div>

      <dl class="audit">
        {
          AUDIT.map((row) => (
            <div class="audit-row">
              <dt>{row.surface}</dt>
              <dd>{row.state}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  #privacy {
    background: #0e1117;
    border-block: 1px solid var(--bar);
  }

  .sec-head {
    margin-bottom: 72px;
  }

  .priv-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 64px;
    align-items: center;
  }

  .priv-btn {
    margin-top: 34px;
  }

  .wire {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .wire-machine {
    background: var(--panel);
    border: 1px solid var(--bar);
    border-radius: var(--radius-l);
    padding: 18px 22px;
    flex-shrink: 0;
  }

  .wire-machine-head {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--mono);
    font-size: 12.5px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .wire-mark {
    color: var(--ash);
  }

  .wire-machine ul {
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ash);
    line-height: 1.9;
  }

  .wire-machine code {
    color: var(--ash);
  }

  .wire-arrow {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    padding: 0 6px;
    min-width: 90px;
  }

  .wire-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted, #5d6577);
    white-space: nowrap;
  }

  .wire-line {
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--bar), var(--ember));
    position: relative;
    border-radius: 2px;
  }

  .wire-line::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3.5px;
    border-left: 8px solid var(--ember);
    border-top: 4.5px solid transparent;
    border-bottom: 4.5px solid transparent;
  }

  .wire-pulse {
    position: absolute;
    top: -2.5px;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 8px 1px rgba(255, 178, 58, 0.55);
    animation: wire-travel 2.8s ease-in-out infinite;
  }

  @keyframes wire-travel {
    0% {
      left: 0%;
      opacity: 0;
    }
    14% {
      opacity: 1;
    }
    86% {
      opacity: 1;
    }
    100% {
      left: calc(100% - 7px);
      opacity: 0;
    }
  }

  .wire-endpoint {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink);
    border: 1px dashed var(--bar);
    border-radius: var(--radius);
    padding: 16px 18px;
    text-align: center;
    flex-shrink: 0;
  }

  .audit {
    margin: 0;
    border: 1px solid var(--bar);
    border-radius: var(--radius-l);
    overflow: hidden;
  }

  .audit-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
    gap: 16px;
    padding: 13px 20px;
    background: var(--panel);
  }

  .audit-row + .audit-row {
    border-top: 1px solid var(--line-soft, rgba(60, 67, 82, 0.6));
  }

  .audit-row dt {
    font-family: var(--mono);
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
  }

  .audit-row dd {
    margin: 0;
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--ash);
  }

  .audit-row dd::before {
    content: '∅ ';
    color: var(--ember-deep);
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .priv-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 48px;
    }
  }

  @media (max-width: 560px) {
    /* one column per row: the surface on top, its state below — two mono
       columns get too cramped to scan on a phone */
    .audit-row {
      grid-template-columns: minmax(0, 1fr);
      gap: 3px;
      padding: 12px 16px;
    }
  }

  @media (max-width: 640px) {
    .wire {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }

    .wire-arrow {
      flex-direction: row-reverse;
      justify-content: flex-end;
      align-items: center;
      gap: 14px;
      padding: 0;
      min-width: 0;
    }

    .wire-label {
      white-space: normal;
    }

    .wire-line {
      width: 2px;
      height: 44px;
      flex-shrink: 0;
      margin-left: 21px;
      background: linear-gradient(180deg, var(--bar), var(--ember));
    }

    .wire-line::after {
      right: -2.75px;
      top: auto;
      bottom: -1px;
      border-left: 4.5px solid transparent;
      border-right: 4.5px solid transparent;
      border-top: 8px solid var(--ember);
      border-bottom: 0;
    }

    .wire-pulse {
      left: -2.5px;
      top: 0;
      animation-name: wire-travel-v;
    }

    .wire-endpoint br {
      display: none;
    }
  }

  @keyframes wire-travel-v {
    0% {
      top: 0;
      opacity: 0;
    }
    14% {
      opacity: 1;
    }
    86% {
      opacity: 1;
    }
    100% {
      top: calc(100% - 7px);
      opacity: 0;
    }
  }
</style>
